OPENAI_API_KEY=your_openai_key_here
DEEPGRAM_API_KEY=your_deepgram_key_here
PORT=3000

# Optional: free Pixabay account → https://pixabay.com/api/docs/
# safesearch=true ensures kids-appropriate images. Without this, falls back to Picsum.
PIXABAY_API_KEY=

# Set to true to skip all images during testing (saves any remaining credits)
DISABLE_IMAGES=false

# ── Persistent storage paths (for Fly.io or similar with mounted volumes) ──────
# On Railway/Render free tier, omit these — caches will be ephemeral but functional.
# On Fly.io, set these to a path inside your mounted volume e.g. /data
# STORIES_DB_PATH=/data/stories.db
# IMAGE_CACHE_DIR=/data/images
# IMAGE_INDEX_FILE=/data/imageIndex.json
# TTS_CACHE_DIR=/data/tts

# When you get Anthropic subscription, add this and revert storyGenerator.js
# ANTHROPIC_API_KEY=
